---
// Marcas con las que trabaja AMG Seguridad — slider full-width (marquee).
interface Brand {
  name: string;
  src: string;
  cat: string;
  h?: number; // alto en px para normalizar visualmente cada logo
}

const brands: Brand[] = [
  { name: 'AJAX', src: '/img/brands/ajax.jpg', cat: 'Alarmas', h: 30 },
  { name: 'DSC', src: '/img/brands/dsc.svg', cat: 'Alarmas', h: 40 },
  { name: 'Hikvision', src: '/img/brands/hikvision.svg', cat: 'Cámaras de vigilancia', h: 26 },
  { name: 'Dahua Technology', src: '/img/brands/dahua.svg', cat: 'Cámaras de vigilancia', h: 40 },
];

// Repetimos el set para que la cinta llene pantallas anchas; luego duplicamos
// todo el track (dos mitades idénticas) para un loop 100% continuo.
const set = [...brands, ...brands, ...brands];
const track = [...set, ...set];
---
<section id="marcas" style="background:#fff;padding:74px 0;border-top:1px solid #E6EAEF;overflow:hidden">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;text-align:center">
    <div style="color:#EA6A1E;font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px">Marcas que trabajamos</div>
    <h2 style="color:#0B2A4A;font-size:clamp(28px,3.4vw,40px);font-weight:800">Equipamiento de las mejores marcas del mercado</h2>
    <p style="color:#5B6875;font-size:16.5px;line-height:1.65;margin-top:18px;max-width:640px;margin-left:auto;margin-right:auto">Instalamos alarmas <strong style="color:#0B2A4A">AJAX</strong> y <strong style="color:#0B2A4A">DSC</strong>, y cámaras de vigilancia <strong style="color:#0B2A4A">Hikvision</strong> y <strong style="color:#0B2A4A">Dahua</strong> — tecnología líder para tu hogar o comercio en Villa María.</p>
  </div>

  <div class="amg-marquee" aria-label="Marcas: AJAX, DSC, Hikvision, Dahua">
    <div class="amg-marquee-track">
      {track.map((b) => (
        <div class="amg-brand" title={`${b.name} — ${b.cat}`}>
          <img src={b.src} alt={`${b.name} — ${b.cat}, instalado por AMG Seguridad en Villa María`} loading="lazy" style={`height:${b.h ?? 34}px;width:auto`} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .amg-marquee {
    margin-top: 44px;
    width: 100%;
    overflow: hidden;
    /* Desvanecido en los bordes para un look premium */
    -webkit-mask-image: linear-gradient(to right, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(to right, transparent, #000 8%, #000 92%, transparent);
  }
  .amg-marquee-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: amgMarquee 34s linear infinite;
  }
  .amg-marquee:hover .amg-marquee-track {
    animation-play-state: paused;
  }
  .amg-brand {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 46px;
    height: 56px;
  }
  .amg-brand img {
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.7;
    transition: filter 0.25s, opacity 0.25s;
  }
  .amg-brand:hover img {
    filter: grayscale(0);
    opacity: 1;
  }
  /* La cinta contiene dos mitades idénticas: -50% = un ciclo perfecto */
  @keyframes amgMarquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (max-width: 600px) {
    .amg-brand { padding: 0 30px; }
    .amg-marquee-track { animation-duration: 24s; }
  }
  @media (prefers-reduced-motion: reduce) {
    .amg-marquee-track { animation: none; }
    .amg-marquee {
      overflow-x: auto;
      -webkit-mask-image: none;
      mask-image: none;
    }
  }
</style>
