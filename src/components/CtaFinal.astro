---
import { BUSINESS, wa } from '../consts';
const waPresupuesto = wa('Hola AMG Seguridad, quiero solicitar un presupuesto');
---
<section style="background:#EA6A1E;padding:60px 24px;position:relative;overflow:hidden">
  <div style="position:absolute;inset:0;background:radial-gradient(circle at 88% 15%,rgba(255,255,255,.16),transparent 50%)"></div>
  <div class="amg-stack" style="position:relative;max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1.3fr .7fr;gap:32px;align-items:center">
    <div>
      <h2 style="color:#fff;font-size:clamp(26px,3.2vw,36px);font-weight:800">Protegé tu hogar o comercio hoy mismo</h2>
      <p style="color:rgba(255,255,255,.9);font-size:17px;line-height:1.55;margin-top:12px">Hablá con un asesor de AMG Seguridad en Villa María. Te armamos una solución a medida, sin cargo y sin compromiso.</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:12px">
      <a href={waPresupuesto} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;justify-content:center;gap:10px;background:#25D366;color:#08331B;font-weight:700;font-size:16px;padding:16px 24px;border-radius:10px;box-shadow:0 10px 26px rgba(8,51,27,.25)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm0 2a8 8 0 1 1-4.2 14.8l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 0 1 12 4zm4.4 9.6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.7.9-.3.2-.5.1a6.5 6.5 0 0 1-1.9-1.2 7.2 7.2 0 0 1-1.3-1.7c-.1-.2 0-.3.1-.5l.4-.4.2-.4v-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a.9.9 0 0 0-.7.3A2.8 2.8 0 0 0 7 9.4a4.9 4.9 0 0 0 1 2.6 11.2 11.2 0 0 0 4.3 3.8c2 .8 2 .5 2.4.5a2.5 2.5 0 0 0 1.6-1.1 2 2 0 0 0 .1-1.1c0-.1-.2-.2-.4-.3z"/></svg>Escribir por WhatsApp</a>
      <a href={`tel:${BUSINESS.phoneTel}`} style="display:inline-flex;align-items:center;justify-content:center;gap:10px;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.4);color:#fff;font-weight:700;font-size:16px;padding:15px 24px;border-radius:10px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>Llamar {BUSINESS.phoneDisplay}</a>
    </div>
  </div>
</section>
