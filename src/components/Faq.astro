---
import { faqs } from '../data/faqs';
---
<section style="background:#fff;padding:88px 24px">
  <div style="max-width:820px;margin:0 auto">
    <div style="text-align:center;margin-bottom:44px">
      <div style="color:#EA6A1E;font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px">Preguntas frecuentes</div>
      <h2 style="color:#0B2A4A;font-size:clamp(28px,3.4vw,38px);font-weight:800">Seguridad electrónica en Villa María: tus dudas</h2>
    </div>
    <div style="display:flex;flex-direction:column;gap:12px">
      {faqs.map((f, i) => (
        <details class="amg-faq" open={i === 0} style="border:1px solid #E6EAEF;border-radius:12px;overflow:hidden;background:#fff">
          <summary style="list-style:none;width:100%;display:flex;align-items:center;justify-content:space-between;gap:16px;text-align:left;cursor:pointer;padding:20px 22px">
            <span style="font-family:Manrope;font-weight:700;color:#0B2A4A;font-size:16.5px">{f.q}</span>
            <span class="amg-faq-sign" style="flex-shrink:0;width:26px;height:26px;border-radius:50%;background:#F1F5FA;color:#EA6A1E;font-weight:700;font-size:20px;line-height:1;display:flex;align-items:center;justify-content:center"></span>
          </summary>
          <div style="padding:0 22px 22px;color:#44515F;font-size:15.5px;line-height:1.65">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .amg-faq summary::-webkit-details-marker {
    display: none;
  }
  .amg-faq-sign::before {
    content: '+';
  }
  .amg-faq[open] .amg-faq-sign::before {
    content: '\2212'; /* − */
  }
</style>
