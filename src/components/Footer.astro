---
import { BUSINESS } from '../consts';
const navItems = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#quienes', label: 'Quiénes Somos' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#clientes', label: 'Clientes' },
  { href: '#contacto', label: 'Contacto' },
];
---
<footer style="background:#071B33;color:#8FA3BC;padding:52px 24px 30px">
  <div class="amg-foot" style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:40px">
    <div>
      <img src={BUSINESS.logo} alt="AMG Seguridad — Villa María, Córdoba" loading="lazy" style="height:48px;width:auto;background:#fff;padding:6px 10px;border-radius:8px" />
      <p style="font-size:14px;line-height:1.65;margin-top:18px;max-width:320px">Seguridad electrónica en Villa María y la región desde 2004. Alarmas monitoreadas, cámaras de seguridad y control de acceso. Marca registrada y homologados.</p>
    </div>
    <div>
      <div style="color:#fff;font-family:Manrope;font-weight:700;font-size:15px;margin-bottom:16px">Navegación</div>
      <div style="display:flex;flex-direction:column;gap:11px;font-size:14px">
        {navItems.map((i) => <a href={i.href} style="color:#8FA3BC">{i.label}</a>)}
      </div>
    </div>
    <div>
      <div style="color:#fff;font-family:Manrope;font-weight:700;font-size:15px;margin-bottom:16px">Contacto</div>
      <div style="display:flex;flex-direction:column;gap:11px;font-size:14px;line-height:1.5">
        <span>Bartolomé Mitre 874<br>Villa María, Córdoba</span>
        <a href={`tel:${BUSINESS.phoneTel}`} style="color:#8FA3BC">Tel. {BUSINESS.phoneDisplay}</a>
        <a href={`https://wa.me/${BUSINESS.whatsappNumber}`} target="_blank" rel="noopener" style="color:#8FA3BC">WhatsApp: {BUSINESS.whatsappDisplay}</a>
        <div style="display:flex;gap:12px;margin-top:6px">
          <a href={BUSINESS.facebook} target="_blank" rel="noopener" aria-label="Facebook" style="color:#8FA3BC"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
          <a href={BUSINESS.instagram} target="_blank" rel="noopener" aria-label="Instagram" style="color:#8FA3BC"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg></a>
        </div>
      </div>
    </div>
  </div>
  <div style="max-width:1200px;margin:36px auto 0;padding-top:22px;border-top:1px solid rgba(255,255,255,.1);display:flex;flex-wrap:wrap;gap:10px;justify-content:space-between;font-size:12.5px;color:#5E738C">
    <span style="color:#5E738C">© 2004–2026 AMG Seguridad. Todos los derechos reservados.</span>
    <span style="color:#5E738C">Villa María · Córdoba · Argentina</span>
  </div>
</footer>
