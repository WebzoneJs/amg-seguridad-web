---
import { BUSINESS, wa } from '../consts';
const waPresupuesto = wa('Hola AMG Seguridad, quiero solicitar un presupuesto');
const checks = ['Presupuesto sin cargo', 'Respuesta en minutos', 'Sin compromiso'];
---
<section id="inicio" style="position:relative;background:#0B2A4A">
  <div style={`position:absolute;inset:0;background-image:url('${BUSINESS.heroImage}');background-size:cover;background-position:center;opacity:.32`}></div>
  <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(7,27,51,.94) 0%,rgba(7,27,51,.82) 45%,rgba(11,42,74,.55) 100%)"></div>
  <div style="position:relative;max-width:1200px;margin:0 auto;padding:96px 24px 104px">
    <div style="max-width:720px">
      <div style="display:inline-flex;align-items:center;gap:9px;background:rgba(234,106,30,.16);border:1px solid rgba(234,106,30,.4);color:#FFB985;font-weight:600;font-size:13px;padding:7px 14px;border-radius:100px;margin-bottom:26px;letter-spacing:.01em">
        <span style="width:8px;height:8px;border-radius:50%;background:#EA6A1E;box-shadow:0 0 0 4px rgba(234,106,30,.25)"></span>Monitoreo activo las 24 hs · 365 días del año
      </div>
      <h1 style="color:#fff;font-size:clamp(34px,5.2vw,58px);font-weight:800">Seguridad electrónica para su hogar y empresa en Villa María</h1>
      <p style="color:#C6D2E0;font-size:clamp(16px,1.7vw,20px);line-height:1.6;margin-top:22px;max-width:600px">Alarmas monitoreadas, cámaras de seguridad HD y control de acceso instalados por especialistas. Protegemos a las familias y comercios de Villa María y la región desde 2004.</p>
      <div style="display:flex;flex-wrap:wrap;gap:14px;margin-top:36px">
        <a href={waPresupuesto} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:10px;background:#25D366;color:#08331B;font-weight:700;font-size:16px;padding:16px 26px;border-radius:10px;box-shadow:0 10px 28px rgba(37,211,102,.28)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm0 2a8 8 0 1 1-4.2 14.8l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 0 1 12 4zm4.4 9.6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.7.9-.3.2-.5.1a6.5 6.5 0 0 1-1.9-1.2 7.2 7.2 0 0 1-1.3-1.7c-.1-.2 0-.3.1-.5l.4-.4.2-.4v-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a.9.9 0 0 0-.7.3A2.8 2.8 0 0 0 7 9.4a4.9 4.9 0 0 0 1 2.6 11.2 11.2 0 0 0 4.3 3.8c2 .8 2 .5 2.4.5a2.5 2.5 0 0 0 1.6-1.1 2 2 0 0 0 .1-1.1c0-.1-.2-.2-.4-.3z"/></svg>Presupuesto sin cargo</a>
        <a href="#servicios" style="display:inline-flex;align-items:center;gap:9px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.28);color:#fff;font-weight:600;font-size:16px;padding:16px 26px;border-radius:10px">Ver servicios</a>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:22px;margin-top:28px">
        {checks.map((c) => (
          <span style="display:flex;align-items:center;gap:8px;color:#C6D2E0;font-size:14px;font-weight:500"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>{c}</span>
        ))}
      </div>
    </div>
  </div>
</section>
