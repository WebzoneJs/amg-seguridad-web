---
import { services } from '../data/services';
import { wa } from '../consts';
const waAsesor = wa('Hola AMG Seguridad, necesito asesoramiento sobre un servicio');
---
<section id="servicios" style="background:#F4F6F9;padding:88px 24px;border-top:1px solid #E6EAEF">
  <div style="max-width:1200px;margin:0 auto">
    <div style="text-align:center;max-width:640px;margin:0 auto 50px">
      <div style="color:#EA6A1E;font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px">Servicios</div>
      <h2 style="color:#0B2A4A;font-size:clamp(28px,3.4vw,40px);font-weight:800">Soluciones integrales de seguridad en Villa María</h2>
      <p style="color:#5B6875;font-size:16.5px;line-height:1.65;margin-top:18px">Instalación, monitoreo y servicio técnico de todos los sistemas que protegen su hogar o comercio.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px">
      {services.map((s) => (
        <div style="background:#fff;border:1px solid #E6EAEF;border-radius:14px;padding:30px;box-shadow:0 1px 3px rgba(11,42,74,.04)">
          <div style="width:52px;height:52px;border-radius:12px;background:#0B2A4A;display:flex;align-items:center;justify-content:center;margin-bottom:20px" set:html={s.icon} />
          <h3 style="color:#0B2A4A;font-size:19px;font-weight:700">{s.title}</h3>
          <p style="color:#5B6875;font-size:15px;line-height:1.6;margin-top:10px">{s.desc}</p>
        </div>
      ))}
    </div>
    <div style="text-align:center;margin-top:44px">
      <a href={waAsesor} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:10px;background:#EA6A1E;color:#fff;font-weight:700;font-size:16px;padding:16px 30px;border-radius:10px;box-shadow:0 10px 26px rgba(234,106,30,.28)">Asesoramiento sin cargo</a>
    </div>
  </div>
</section>
