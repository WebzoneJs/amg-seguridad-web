---
import { BUSINESS } from '../consts';
---
<div style="background:#071B33;color:#B9C6D6;font-size:13px">
  <div style="max-width:1200px;margin:0 auto;padding:9px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:22px;flex-wrap:wrap">
      <a href={`tel:${BUSINESS.phoneTel}`} style="color:#B9C6D6;display:flex;align-items:center;gap:7px;font-weight:500"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#EA6A1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>{BUSINESS.phoneDisplay}</a>
      <span class="amg-desk" style="display:flex;align-items:center;gap:7px"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#EA6A1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>{BUSINESS.streetAddress}, {BUSINESS.city}, {BUSINESS.region}</span>
    </div>
    <div style="display:flex;align-items:center;gap:16px">
      <span class="amg-desk" style="color:#7E8FA3">Atención 24 hs · 365 días</span>
      <a href={BUSINESS.facebook} target="_blank" rel="noopener" aria-label="Facebook de AMG Seguridad" style="color:#B9C6D6;display:flex"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
      <a href={BUSINESS.instagram} target="_blank" rel="noopener" aria-label="Instagram de AMG Seguridad" style="color:#B9C6D6;display:flex"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg></a>
    </div>
  </div>
</div>
