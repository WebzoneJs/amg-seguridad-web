---
const badges = [
  {
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
    title: 'Homologados',
    sub: 'Monitoreo de alarmas y cámaras',
  },
  {
    icon: '<path d="M12 2l2.4 4.9 5.4.8-3.9 3.8.9 5.4-4.8-2.5-4.8 2.5.9-5.4L4.2 7.7l5.4-.8z"/>',
    title: 'Marca registrada',
    sub: 'Empresa habilitada y confiable',
  },
  {
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
    title: '+20 años',
    sub: 'Experiencia desde 2004',
  },
  {
    icon: '<path d="M12 21s-8-4.5-8-11a4 4 0 0 1 8-1 4 4 0 0 1 8 1c0 6.5-8 11-8 11z" fill="none"/><path d="M3 12h4l2 4 3-8 2 4h5"/>',
    title: 'Villa María y región',
    sub: 'Cobertura en toda la zona',
  },
];
---
<div style="background:#fff;border-bottom:1px solid #E6EAEF">
  <div style="max-width:1200px;margin:0 auto;padding:26px 24px;display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:18px">
    {badges.map((b) => (
      <div style="display:flex;align-items:center;gap:14px">
        <div style="width:44px;height:44px;border-radius:10px;background:#F1F5FA;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0B2A4A" stroke-width="1.8" set:html={b.icon} /></div>
        <div><div style="font-family:Manrope;font-weight:700;color:#0B2A4A;font-size:15px">{b.title}</div><div style="font-size:13px;color:#5B6875">{b.sub}</div></div>
      </div>
    ))}
  </div>
</div>
