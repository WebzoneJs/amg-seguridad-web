---
import Base from '../layouts/Base.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBadges from '../components/TrustBadges.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Brands from '../components/Brands.astro';
import Stats from '../components/Stats.astro';
import Clients from '../components/Clients.astro';
import Payments from '../components/Payments.astro';
import Faq from '../components/Faq.astro';
import Contact from '../components/Contact.astro';
import CtaFinal from '../components/CtaFinal.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsapp from '../components/FloatingWhatsapp.astro';
---
<Base>
  <link slot="head" rel="preload" as="image" href="/img/hero.jpg" fetchpriority="high" />
  <TopBar />
  <Header />
  <Hero />
  <TrustBadges />
  <About />
  <Services />
  <Brands />
  <Stats />
  <Clients />
  <Payments />
  <Faq />
  <Contact />
  <CtaFinal />
  <Footer />
  <FloatingWhatsapp />
</Base>
